{
  "variables": {
    "aws_access_key": "{{env `AWS_ACCESS_KEY`}}",
    "aws_secret_key": "{{env `AWS_SECRET_KEY`}}",
    "version": "{{env `VERSION`}}",
    "ami-comment": "ubuntu/images/hvm-ssd/ubuntu-jammy-22.04-amd64-server-20230208 - ami-0557a15b87f6559cf"
  },
  "builders": [
    {
      "type": "amazon-ebs",
      "region": "us-east-1",
      "source_ami": "ami-0557a15b87f6559cf",
      "instance_type": "g6e.2xlarge",
      "ssh_username": "ubuntu",
      "aws_polling": {
        "delay_seconds": 60,
        "max_attempts": 60
      },
      "ami_name": "ordinary-experts-patterns-open-webui-{{user `version`}}-{{isotime \"20060102-0304\"}}",
      "launch_block_device_mappings": [{
        "device_name": "/dev/sda1",
        "volume_type": "gp3",
        "volume_size": 100,
        "delete_on_termination": true
      }]
    }
  ],
  "provisioners": [
    {
      "type": "shell",
      "execute_command": "{{.Vars}} sudo -H -S -E bash '{{.Path}}'",
      "script": "./packer/ubuntu_2204_appinstall.sh"
    }
  ],
  "post-processors": [
    [
      {
        "output": "manifest.json",
        "strip_path": true,
        "type": "manifest"
      }
    ]
  ]
}
